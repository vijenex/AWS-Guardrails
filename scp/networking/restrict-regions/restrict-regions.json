{
  "_meta": {
    "source": "https://github.com/vijenex/AWS-Guardrails",
    "author": "Vijenex™ — https://vijenex.com",
    "license": "Apache-2.0",
    "description": "Restrict resource creation to an approved set of AWS regions — block all other regions to limit blast radius and data residency scope",
    "protects_against": "Data residency violations, resource sprawl in unapproved regions, increased attack surface from unused regions",
    "last_validated": "2026-06"
  },
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "DenyResourceCreationOutsideApprovedRegions",
      "Effect": "Deny",
      "Action": [
        "ec2:RunInstances",
        "ec2:CreateKeyPair",
        "ec2:CreateSecurityGroup",
        "ec2:CreateVolume",
        "ec2:CreateNetworkInterface",
        "ec2:CreateSnapshot",
        "ec2:CreateImage",
        "ec2:CreateVpc",
        "ec2:CreateSubnet",
        "ec2:CreateRoute",
        "ec2:CreateRouteTable",
        "ec2:CreateInternetGateway",
        "ec2:CreateNatGateway",
        "ec2:CreateVpnGateway",
        "ec2:CreateCustomerGateway",
        "ec2:CreateDhcpOptions",
        "ec2:CreatePlacementGroup",
        "ec2:CreateNetworkAcl",
        "ec2:CreateNetworkAclEntry",
        "s3:CreateBucket",
        "s3:PutBucketPolicy",
        "s3:PutBucketAcl",
        "iam:CreateUser",
        "iam:CreateGroup",
        "iam:CreateRole",
        "iam:CreatePolicy",
        "iam:CreateInstanceProfile",
        "rds:CreateDBInstance",
        "rds:CreateDBCluster",
        "rds:CreateDBSnapshot",
        "lambda:CreateFunction",
        "lambda:CreateEventSourceMapping",
        "dynamodb:CreateTable",
        "dynamodb:CreateGlobalTable",
        "cloudformation:CreateStack",
        "cloudfront:CreateDistribution",
        "cloudwatch:PutMetricAlarm",
        "sns:CreateTopic",
        "sqs:CreateQueue",
        "elasticbeanstalk:CreateApplication",
        "elasticbeanstalk:CreateEnvironment",
        "ecs:CreateCluster",
        "ecs:RegisterTaskDefinition",
        "eks:CreateCluster",
        "eks:CreateFargateProfile",
        "route53:CreateHostedZone",
        "codebuild:CreateProject",
        "codepipeline:CreatePipeline",
        "waf:CreateWebACL",
        "apigateway:CreateRestApi",
        "kinesis:CreateStream",
        "servicecatalog:CreatePortfolio",
        "servicecatalog:CreateProduct",
        "workspaces:CreateWorkspaces",
        "codecommit:CreateRepository",
        "cognito-identity:CreatePool",
        "secretsmanager:CreateSecret",
        "kms:CreateKey",
        "kms:EnableKey",
        "kms:CreateAlias",
        "ses:CreateConfigurationSet",
        "elasticache:CreateCacheCluster",
        "elasticache:CreateReplicationGroup",
        "sagemaker:CreateTrainingJob",
        "sagemaker:CreateEndpoint",
        "sagemaker:CreateModel",
        "bedrock:InvokeModel",
        "bedrock:ListFoundationModels",
        "ecr:CreateRepository",
        "memorydb:CreateCluster",
        "glue:CreateJob",
        "glue:StartJobRun",
        "athena:StartQueryExecution",
        "athena:CreateWorkGroup",
        "quicksight:CreateDashboard",
        "quicksight:CreateAnalysis",
        "lakeformation:GrantPermissions",
        "lakeformation:CreateLFTag",
        "airflow:CreateEnvironment",
        "redshift:CreateCluster",
        "redshift:CreateClusterSubnetGroup",
        "kafka:CreateCluster",
        "kafka:CreateClusterV2",
        "firehose:CreateDeliveryStream"
      ],
      "Resource": "*",
      "Condition": {
        "StringNotEquals": {
          "aws:RequestedRegion": [
            "REPLACE_WITH_YOUR_PRIMARY_REGION",
            "REPLACE_WITH_YOUR_SECONDARY_REGION"
          ]
        }
      }
    }
  ]
}
