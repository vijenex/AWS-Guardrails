{
  "_meta": {
    "source": "https://github.com/vijenex/AWS-Guardrails",
    "author": "Vijenex™ — https://vijenex.com",
    "license": "Apache-2.0",
    "description": "Require mandatory tags on Secrets Manager secrets and prevent removing the owner tag — enables secret ownership tracking and governance",
    "protects_against": "Orphaned secrets with no owner, secrets created without accountability, untracked credentials in Secrets Manager",
    "last_validated": "2026-06"
  },
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "DenyCreateSecretWithoutOwnerEmail",
      "Effect": "Deny",
      "Action": "secretsmanager:CreateSecret",
      "Resource": "*",
      "Condition": {
        "Null": {
          "aws:RequestTag/Email": "true"
        }
      }
    },
    {
      "Sid": "DenyRemovingOwnerEmailTag",
      "Effect": "Deny",
      "Action": "secretsmanager:UntagResource",
      "Resource": "*",
      "Condition": {
        "ForAnyValue:StringEquals": {
          "aws:TagKeys": [
            "Email"
          ]
        }
      }
    },
    {
      "Sid": "DenyCreateSecretWithoutOwnerTag",
      "Effect": "Deny",
      "Action": "secretsmanager:CreateSecret",
      "Resource": "*",
      "Condition": {
        "Null": {
          "aws:RequestTag/Owner": "true"
        }
      }
    }
  ]
}
